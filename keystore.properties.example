# Copy to keystore.properties (gitignored) at the project root for local release builds.
# CI does not use this file — it injects the same four values via environment variables
# (RELEASE_KEYSTORE_PATH, RELEASE_KEYSTORE_PASSWORD, RELEASE_KEY_ALIAS, RELEASE_KEY_PASSWORD)
# from repository secrets instead. See app/build.gradle.kts's signingConfigs block.
storeFile=/absolute/path/to/upload-keystore.jks
storePassword=
keyAlias=
keyPassword=
